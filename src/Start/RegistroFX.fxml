                  <Font name="Montserrat Black" size="12.0" />
               </font>
            </Button>
                <Pane fx:id="overlay" mouseTransparent="true" opacity="0.0" prefHeight="593.0" prefWidth="663.0" style="-fx-background-color: black;" />
            <ImageView fx:id="iconMoon" fitHeight="47.0" fitWidth="43.0" layoutX="620.0" layoutY="550.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../Img/Icons/MoonStars.png" />
               </image>
            </ImageView>
            <Button fx:id="btnDarkOff" layoutX="619.0" layoutY="549.0" onAction="#cambiarModo" prefHeight="43.0" prefWidth="43.0" style="-fx-background-color: transparent;" text="   " />
         </children>
      </Pane>
   </children>
